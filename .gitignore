# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Mac System Files
.DS_Store

# Repo-wide
.env*

# Common generated files
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
htmlcov/
*.log
__pycache__/
*.py[cod]

# Tool-specific leftovers
.idea/
.vscode/
*.code-workspace

# Environments
.venv/
venv/
env/

# Web dependencies
/web/node_modules
/web/.pnp
/web/.pnp.*
/web/.yarn/*
/web/!.yarn/patches
/web/!.yarn/plugins
/web/!.yarn/releases
/web/!.yarn/versions

# testing
/web/coverage

# next.js
/web/.next/
/web/out/

# production
/web/build

# misc
/web/*.pem

# debug
/web/npm-debug.log*
/web/yarn-debug.log*
/web/yarn-error.log*
/web/.pnpm-debug.log*

# vercel
/web/.vercel

# typescript
/web/*.tsbuildinfo
/web/next-env.d.ts